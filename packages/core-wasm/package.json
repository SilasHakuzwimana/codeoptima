{
  "name": "codeoptima-core-wasm",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./pkg/codeoptima_wasm.js",
      "types": "./pkg/codeoptima_wasm.d.ts"
    }
  },
  "scripts": {
    "build:wasm": "wasm-pack build --target web --out-dir pkg --release",
