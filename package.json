{
  "name": "codeoptima-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "turbo dev --parallel",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules",
    "extension:package": "pnpm --filter extension package",
    "extension:publish": "pnpm --filter extension publish",
    "backend:dev": "pnpm --filter backend dev",
    "backend:deploy": "pnpm --filter backend deploy"
  },
  "devDependencies": {
    "turbo": "^1.12.0",
    "typescript": "5.3.3",
    "@types/node": "20.10.5",
    "prettier": "^3.1.1",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  
  "pnpm": {
    "patchedDependencies": {
      "vscode-languageclient@9.0.1": "patches/vscode-languageclient+9.0.1.patch"
    },
    "overrides": {
      "axios": "1.6.2",
      "semver": "7.5.4",
      "follow-redirects": "1.15.4",
      
      "typescript": "$typescript"
    },
    "neverBuiltDependencies": ["fsevents", "sharp"]
  },
  "dependencies": {
    "codeoptima-shared-types": "workspace:*" 
  }
}